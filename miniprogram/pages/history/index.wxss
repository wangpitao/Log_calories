page {
  background: #F2F2F7;
  color: #1D1D1F;
}

.page {
  padding: 40rpx 30rpx 70rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.subtitle {
  color: #7A858C;
  font-size: 26rpx;
  margin-bottom: 32rpx;
}

.summary-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.summary-item {
  width: 31.5%;
  background: #fff;
  border-radius: 30rpx;
  padding: 30rpx 12rpx;
  text-align: center;
  box-shadow: 0 18rpx 50rpx rgba(31, 35, 41, 0.06);
}

.summary-value {
  display: block;
  font-size: 42rpx;
  font-weight: 900;
  color: #20C997;
  margin-bottom: 8rpx;
}

.summary-label {
  color: #7A858C;
  font-size: 22rpx;
}

.chart-card,
.detail-list {
  background: #fff;
  border-radius: 34rpx;
  padding: 32rpx;
  box-shadow: 0 18rpx 50rpx rgba(31, 35, 41, 0.06);
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
}

.day-row {
  display: flex;
  align-items: center;
  height: 58rpx;
}

.day-date {
  width: 76rpx;
  color: #6F7A82;
  font-size: 24rpx;
}

.bar-track {
  flex: 1;
  height: 18rpx;
  border-radius: 9rpx;
  background: #E5E5EA;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 9rpx;
  background: linear-gradient(90deg, #20C997, #53D6B1);
}

.day-cal {
  width: 86rpx;
  text-align: right;
  color: #1D1D1F;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-list {
  padding: 8rpx 32rpx;
}

.detail-item {
  padding: 28rpx 0;
  border-bottom: 1px solid #EFEFF4;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-head,
.detail-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-head {
  margin-bottom: 14rpx;
}

.detail-date {
  font-size: 30rpx;
  font-weight: 800;
}

.detail-count {
  font-size: 24rpx;
  color: #7A858C;
}

.detail-cal {
  font-size: 28rpx;
  color: #20C997;
  font-weight: 900;
}

.detail-macro {
  font-size: 23rpx;
  color: #7A858C;
}

page {
  background: #F2F2F7;
  color: #1D1D1F;
}

.page {
  padding: 40rpx 30rpx 70rpx;
}

.brand-card {
  background: #fff;
  border-radius: 34rpx;
  padding: 46rpx 36rpx;
  box-shadow: 0 18rpx 50rpx rgba(31, 35, 41, 0.06);
  margin-bottom: 30rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: 900;
  color: #20C997;
  margin-bottom: 18rpx;
}

.brand-desc {
  color: #56626A;
  font-size: 28rpx;
  line-height: 1.7;
}

.section {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 14rpx;
}

.section-text {
  color: #6F7A82;
  font-size: 26rpx;
  line-height: 1.7;
}

.version {
  margin-top: 36rpx;
  text-align: center;
  color: #A0A8AD;
  font-size: 24rpx;
}

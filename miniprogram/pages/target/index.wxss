page {
  background: #F2F2F7;
  color: #1D1D1F;
}

.page {
  padding: 40rpx 30rpx 70rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #7A858C;
  margin-bottom: 34rpx;
}

.form-card {
  background: #fff;
  border-radius: 34rpx;
  padding: 12rpx 34rpx;
  box-shadow: 0 18rpx 50rpx rgba(31, 35, 41, 0.06);
}

.field {
  padding: 28rpx 0;
  border-bottom: 1px solid #EFEFF4;
}

.field:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.input-row {
  display: flex;
  align-items: center;
  background: #F2F2F7;
  border-radius: 24rpx;
  height: 86rpx;
  padding: 0 24rpx;
}

.input {
  flex: 1;
  color: #1D1D1F;
  font-size: 34rpx;
  font-weight: 800;
}

.unit {
  color: #7A858C;
  font-size: 26rpx;
  margin-left: 16rpx;
}

.save-btn {
  margin: 42rpx 0 0;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  background: #20C997;
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
}

.save-btn::after {
  border: none;
}
